svivy.ru {
		
	handle /coursework-pdf {
		root * /var/www/static
		rewrite * /coursework.pdf
		file_server
	}
	
	handle /coursework-docx {
		root * /var/www/static
		rewrite * /coursework.docx
		file_server
	}

	handle /api/* {
                reverse_proxy backend:8080
        }	

	handle {
		reverse_proxy frontend:80
	}

}
